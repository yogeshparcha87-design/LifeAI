# ======================================
# LifeAI Environment Configuration
# ======================================

# Application
APP_NAME=LifeAI
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=True

# Server
HOST=127.0.0.1
PORT=8000

# Database
DATABASE_URL=sqlite:///lifeai.db

# AI Model
AI_PROVIDER=ollama
AI_MODEL=llama3.2

# Ollama
OLLAMA_HOST=http://localhost:11434

# Memory
MEMORY_ENABLED=True

# Authentication
SECRET_KEY=your_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Keys (Replace with your own if needed)
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Logging
LOG_LEVEL=INFO

# Features
ENABLE_CHAT=True
ENABLE_NOTES=True
ENABLE_TODO=True
ENABLE_GOALS=True
ENABLE_MEMORY=True
ENABLE_VOICE=False
ENABLE_CAMERA=False
ENABLE_FINANCE=False

# Notifications
NOTIFICATION_ENABLED=True

# Backup
AUTO_BACKUP=False
